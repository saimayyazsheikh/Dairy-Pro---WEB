                        "medicineCost": {
                            ".validate": "!newData.exists() || newData.isNumber()"
                        },
                        "doctorFee": {
                            ".validate": "!newData.exists() || newData.isNumber()"
                        },
                        "nextDueDate": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "semenName": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "semenCompany": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "semenColor": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "expectedDeliveryDate": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "createdAt": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "$other": {
                            ".validate": false
                        }
                    }
                },
                "inventory": {
                    ".indexOn": [
                        "name",
                        "quantity",
