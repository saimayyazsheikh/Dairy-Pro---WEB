                        },
                        "hospital": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "visitSchedule": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "createdAt": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "updatedAt": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "$other": {
                            ".validate": false
                        }
                    }
                },
                "milk_records": {
                    ".indexOn": [
                        "date",
                        "vendorId",
                        "createdAt"
                    ],
                    "$recordId": {
                        ".validate": "newData.hasChildren(['date', 'quantity', 'totalAmount'])",
                        "date": {
                            ".validate": "newData.isString()"
                        },
                        "session": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "vendorId": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "vendorName": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "quantity": {
