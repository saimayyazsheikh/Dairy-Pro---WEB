                    ],
                    "$usageId": {
                        ".validate": "newData.hasChildren(['itemId', 'quantity'])",
                        "itemId": {
                            ".validate": "newData.isString()"
                        },
                        "itemName": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "quantity": {
                            ".validate": "newData.isNumber()"
                        },
                        "unit": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "allocatedTo": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "note": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "date": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "$other": {
                            ".validate": false
                        }
                    }
                },
                "inventory_templates": {
                    "$templateId": {
                        ".validate": "newData.hasChildren(['itemId', 'quantity'])",
                        "itemId": {
                            ".validate": "newData.isString()"
                        },
                        "itemName": {
                            ".validate": "newData.isString()"
                        },
                        "quantity": {
                            ".validate": "newData.isNumber()"
                        },
                        "unit": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "isActive": {
                            ".validate": "newData.isBoolean()"
                        },
                        "note": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "lastRunDate": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "createdAt": {
                            ".validate": "newData.isString()"
                        },
                        "$other": {
                            ".validate": false
                        }
                    }
                },
                "payroll_runs": {
                    "$month": {
                        "$empId": {
                            ".validate": "newData.hasChildren(['amount', 'date'])",
                            "amount": {
                                ".validate": "newData.isNumber()"
                            },
                            "date": {
                                ".validate": "newData.isString()"
                            },
                            "status": {
                                ".validate": "newData.isString()"
                            },
                            "$other": {
                                ".validate": false
                            }
                        }
                    }
                },
                "expenses": {
                    ".indexOn": [
                        "referenceId",
                        "date"
                    ],
                    "$expenseId": {
                        ".validate": "newData.hasChildren(['date', 'category', 'amount'])",
                        "date": {
                            ".validate": "newData.isString()"
                        },
                        "category": {
                            ".validate": "newData.isString()"
                        },
                        "amount": {
                            ".validate": "newData.isNumber()"
                        },
                        "description": {
                            ".validate": "!newData.exists() || newData.isString()"
