{
    "rules": {
        "users": {
            "$uid": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
            }
        },
        "farms": {
            "$farmId": {
                ".read": "root.child('users').child(auth.uid).child('farmId').val() === $farmId",
                ".write": "root.child('users').child(auth.uid).child('farmId').val() === $farmId || newData.child('ownerId').val() === auth.uid",
                "cattle": {
                    ".indexOn": [
                        "tagId",
                        "status",
                        "createdAt"
                    ],
                    "$cattleId": {
                        ".validate": "newData.hasChildren(['tagId'])",
                        "tagId": {
                            ".validate": "newData.isString() && newData.val().length > 0"
                        },
                        "name": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "type": {
                            ".validate": "newData.isString()"
                        },
                        "breed": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "gender": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "dob": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "purchasedYear": {
                            ".validate": "!newData.exists() || newData.isString() || newData.isNumber()"
                        },
                        "status": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "weight": {
                            ".validate": "!newData.exists() || newData.isNumber() || newData.isString()"
                        },
                        "bms": {
                            ".validate": "!newData.exists() || newData.isNumber() || newData.isString()"
                        },
                        "motherId": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "fatherSemenCompany": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "location": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "vaccinationDate": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "vaccinationType": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "turnOfPregnancy": {
                            ".validate": "!newData.exists() || newData.isNumber() || newData.isString()"
                        },
                        "inseminationDate": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "expectedDeliveryDate": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "createdAt": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "updatedAt": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "$other": {
                            ".validate": false
                        }
                    }
                },
                "production_logs": {
                    ".indexOn": [
                        "date",
                        "cowTag",
                        "createdAt"
                    ],
                    "$logId": {
                        ".validate": "newData.hasChildren(['date', 'liters'])",
                        "cowTag": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "cowId": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "date": {
                            ".validate": "newData.isString()"
                        },
                        "session": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "liters": {
                            ".validate": "newData.isNumber()"
                        },
                        "fat": {
                            ".validate": "!newData.exists() || newData.isNumber()"
                        },
                        "snf": {
                            ".validate": "!newData.exists() || newData.isNumber()"
                        },
                        "quality": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "note": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "createdAt": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "$other": {
                            ".validate": false
                        }
                    }
                },
                "health_records": {
                    ".indexOn": [
                        "date",
                        "cowTag",
                        "createdAt"
                    ],
                    "$recordId": {
                        ".validate": "newData.hasChildren(['date', 'recordType'])",
