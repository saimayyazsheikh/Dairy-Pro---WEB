                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "treatment": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "vaccineName": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "symptoms": {
                            ".validate": "!newData.exists() || newData.isString()"
                        },
                        "cost": {
                            ".validate": "!newData.exists() || newData.isNumber()"
